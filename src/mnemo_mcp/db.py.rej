+    def _calc_recency(self, mem: dict, now: datetime) -> float:
+        """Calculate recency score (0.0 to 1.0)."""
+        try:
+            updated = datetime.fromisoformat(mem["updated_at"])
+            days_old = (now - updated).total_seconds() / 86400
+            return 2.0 ** (-days_old / 7.0)
+        except (ValueError, KeyError):
+            return 0.0
+
+    def _calc_frequency(self, mem: dict) -> float:
+        """Calculate frequency score (0.0 to 1.0)."""
+        freq = math.log1p(mem.get("access_count", 0)) / 10.0
+        return min(freq, 1.0)
+
+    def _update_access_stats(self, top_results: list[dict]) -> None:
+        """Update access count and last_accessed for top results."""
+        ids = [m["id"] for m in top_results]
+        placeholders = ",".join("?" for _ in ids)
+        self._conn.execute(
+            f"""UPDATE memories
+                SET access_count = access_count + 1,
+                    last_accessed = ?
+                WHERE id IN ({placeholders})""",
+            [_now_iso(), *ids],
+        )
+        self._conn.commit()
 
