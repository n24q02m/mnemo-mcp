{
  "name": "mnemo-mcp",
  "version": "1.12.0",
  "description": "Persistent AI memory — store, search, and recall knowledge across sessions",
  "mcpServers": {
    "mnemo": {
      "command": "uvx",
      "args": [
        "--python",
        "3.13",
        "mnemo-mcp"
      ],
      "env": {
        "RERANK_ENABLED": "true"
      }
    }
  },
  "settings": [
    {
      "name": "API Keys",
      "description": "Cloud embedding keys (format: GOOGLE_API_KEY:xxx,COHERE_API_KEY:yyy)",
      "envVar": "API_KEYS",
      "sensitive": true
    }
  ]
}
