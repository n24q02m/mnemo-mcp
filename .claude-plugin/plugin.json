{
  "name": "mnemo-mcp",
  "description": "Persistent AI memory — store, search, and recall knowledge across sessions",
  "version": "1.25.0",
  "userConfig": {
    "JINA_AI_API_KEY": {
      "type": "string",
      "title": "Jina AI API key (optional)",
      "description": "Optional cloud reranker key. https://jina.ai/api-dashboard/",
      "sensitive": true,
      "required": false
    },
    "GEMINI_API_KEY": {
      "type": "string",
      "title": "Gemini API key (optional)",
      "description": "Optional cloud embedding + LLM. Free tier available. https://aistudio.google.com/apikey",
      "sensitive": true,
      "required": false
    },
    "OPENAI_API_KEY": {
      "type": "string",
      "title": "OpenAI API key (optional)",
      "description": "Optional cloud embedding + LLM (lower priority than Gemini). https://platform.openai.com/api-keys",
      "sensitive": true,
      "required": false
    },
    "COHERE_API_KEY": {
      "type": "string",
      "title": "Cohere API key (optional)",
      "description": "Optional cloud embedding + reranking. https://dashboard.cohere.com/api-keys",
      "sensitive": true,
      "required": false
    }
  },
  "author": {
    "name": "n24q02m",
    "url": "https://github.com/n24q02m"
  },
  "homepage": "https://github.com/n24q02m/mnemo-mcp",
  "mcpServers": {
    "mnemo": {
      "command": "uvx",
      "args": [
        "--python",
        "3.13",
        "mnemo-mcp"
      ],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "JINA_AI_API_KEY": "${user_config.JINA_AI_API_KEY}",
        "GEMINI_API_KEY": "${user_config.GEMINI_API_KEY}",
        "OPENAI_API_KEY": "${user_config.OPENAI_API_KEY}",
        "COHERE_API_KEY": "${user_config.COHERE_API_KEY}"
      }
    }
  }
}
